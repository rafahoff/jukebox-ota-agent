# Gerido por pi_install_ota.sh — não editar à mão no Pi.
# Permite ao kiosk (utilizador jukebox) disparar check/upgrade OTA como jukebox-ota.
Defaults:jukebox !requiretty
Cmnd_Alias JUKEEO_OTA_CHECK = /opt/jukeeo/ota-agent/jukebox-ota-agent check --config /etc/jukeeo/ota-agent.json, \
    /opt/jukeeo/ota-agent/jukebox-ota-agent check --config /etc/jukeeo/ota-agent.json --force
Cmnd_Alias JUKEEO_OTA_UPGRADE = /opt/jukeeo/ota-agent/jukebox-ota-agent upgrade --config /etc/jukeeo/ota-agent.json, \
    /opt/jukeeo/ota-agent/jukebox-ota-agent upgrade --config /etc/jukeeo/ota-agent.json --force
jukebox ALL=(jukebox-ota) NOPASSWD: JUKEEO_OTA_CHECK, JUKEEO_OTA_UPGRADE
